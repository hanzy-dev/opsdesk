package auth

import (
	"context"
	"crypto"
	"crypto/rsa"
	"crypto/sha256"
	"encoding/base64"
	"encoding/json"
	"errors"
	"fmt"
	"math/big"
	"net/http"
	"strings"
	"sync"
	"time"
)

var (
	ErrMissingAuthorization = errors.New("missing authorization header")
	ErrInvalidAuthorization = errors.New("invalid authorization header")
	ErrInvalidToken         = errors.New("invalid token")
)

type Verifier interface {
	VerifyToken(ctx context.Context, token string) (Identity, error)
}

type CognitoVerifier struct {
	httpClient  *http.Client
	issuer      string
	jwksURL     string
	appClientID string

	mu   sync.RWMutex
	keys map[string]*rsa.PublicKey
}

type cognitoJWTHeader struct {
	Algorithm string `json:"alg"`
	KeyID     string `json:"kid"`
	Type      string `json:"typ"`
}

type cognitoClaims struct {
	Subject         string   `json:"sub"`
	Issuer          string   `json:"iss"`
	Expiration      int64    `json:"exp"`
	TokenUse        string   `json:"token_use"`
	ClientID        string   `json:"client_id"`
	Audience        string   `json:"aud"`
	Username        string   `json:"username"`
	CognitoUsername string   `json:"cognito:username"`
	Email           string   `json:"email"`
	Name            string   `json:"name"`
	Groups          []string `json:"cognito:groups"`
}

type jwksDocument struct {
	Keys []jwk `json:"keys"`
}

type jwk struct {
	KeyID string `json:"kid"`
	Kty   string `json:"kty"`
	N     string `json:"n"`
	E     string `json:"e"`
}

func NewCognitoVerifier(region, userPoolID, appClientID string) (*CognitoVerifier, error) {
	if strings.TrimSpace(region) == "" {
		return nil, errors.New("COGNITO_REGION is required")
	}

	if strings.TrimSpace(userPoolID) == "" {
		return nil, errors.New("COGNITO_USER_POOL_ID is required")
	}

	if strings.TrimSpace(appClientID) == "" {
		return nil, errors.New("COGNITO_APP_CLIENT_ID is required")
	}

	issuer := fmt.Sprintf("https://cognito-idp.%s.amazonaws.com/%s", region, userPoolID)

	return &CognitoVerifier{
		httpClient: &http.Client{Timeout: 5 * time.Second},
		issuer:     issuer,
		jwksURL:    issuer + "/.well-known/jwks.json",
		appClientID: appClientID,
		keys:       make(map[string]*rsa.PublicKey),
	}, nil
}

func (v *CognitoVerifier) VerifyToken(ctx context.Context, token string) (Identity, error) {
	header, claims, signingInput, signature, err := parseJWT(token)
	if err != nil {
		return Identity{}, err
	}

	if header.Algorithm != "RS256" || strings.TrimSpace(header.KeyID) == "" {
		return Identity{}, ErrInvalidToken
	}

	key, err := v.publicKeyFor(ctx, header.KeyID)
	if err != nil {
		return Identity{}, err
	}

	if err := verifyRS256Signature(key, signingInput, signature); err != nil {
		return Identity{}, ErrInvalidToken
	}

	if claims.Issuer != v.issuer {
		return Identity{}, ErrInvalidToken
	}

	if claims.Expiration <= time.Now().Unix() {
		return Identity{}, ErrInvalidToken
	}

	if claims.TokenUse != "id" {
		return Identity{}, ErrInvalidToken
	}

	if claims.Audience != v.appClientID {
		return Identity{}, ErrInvalidToken
	}

	username := claims.Username
	if username == "" {
		username = claims.CognitoUsername
	}

	if claims.Subject == "" || username == "" || claims.Email == "" {
		return Identity{}, ErrInvalidToken
	}

	return Identity{
		Subject:  claims.Subject,
		Username: username,
		Email:    claims.Email,
		Name:     claims.Name,
		TokenUse: claims.TokenUse,
		Role:     ResolveRole(claims.Groups),
		Groups:   claims.Groups,
	}, nil
}

func ExtractBearerToken(headerValue string) (string, error) {
	if strings.TrimSpace(headerValue) == "" {
		return "", ErrMissingAuthorization
	}

	parts := strings.SplitN(headerValue, " ", 2)
	if len(parts) != 2 || !strings.EqualFold(parts[0], "Bearer") || strings.TrimSpace(parts[1]) == "" {
		return "", ErrInvalidAuthorization
	}

	return strings.TrimSpace(parts[1]), nil
}

func (v *CognitoVerifier) publicKeyFor(ctx context.Context, keyID string) (*rsa.PublicKey, error) {
	v.mu.RLock()
	key := v.keys[keyID]
	v.mu.RUnlock()
	if key != nil {
		return key, nil
	}

	if err := v.refreshKeys(ctx); err != nil {
		return nil, err
	}

	v.mu.RLock()
	defer v.mu.RUnlock()
	key = v.keys[keyID]
	if key == nil {
		return nil, ErrInvalidToken
	}

	return key, nil
}

func (v *CognitoVerifier) refreshKeys(ctx context.Context) error {
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, v.jwksURL, nil)
	if err != nil {
		return err
	}

	response, err := v.httpClient.Do(req)
	if err != nil {
		return err
	}
	defer response.Body.Close()

	if response.StatusCode != http.StatusOK {
		return ErrInvalidToken
	}

	var document jwksDocument
	if err := json.NewDecoder(response.Body).Decode(&document); err != nil {
		return err
	}

	keys := make(map[string]*rsa.PublicKey, len(document.Keys))
	for _, currentKey := range document.Keys {
		if currentKey.Kty != "RSA" || currentKey.KeyID == "" {
			continue
		}

		publicKey, err := parseRSAPublicKey(currentKey.N, currentKey.E)
		if err != nil {
			continue
		}

		keys[currentKey.KeyID] = publicKey
	}

	v.mu.Lock()
	v.keys = keys
	v.mu.Unlock()
	return nil
}

func parseJWT(token string) (cognitoJWTHeader, cognitoClaims, string, []byte, error) {
	var header cognitoJWTHeader
	var claims cognitoClaims

	segments := strings.Split(token, ".")
	if len(segments) != 3 {
		return header, claims, "", nil, ErrInvalidToken
	}

	headerBytes, err := decodeJWTPart(segments[0])
	if err != nil {
		return header, claims, "", nil, ErrInvalidToken
	}

	claimsBytes, err := decodeJWTPart(segments[1])
	if err != nil {
		return header, claims, "", nil, ErrInvalidToken
	}

	signature, err := base64.RawURLEncoding.DecodeString(segments[2])
	if err != nil {
		return header, claims, "", nil, ErrInvalidToken
	}

	if err := json.Unmarshal(headerBytes, &header); err != nil {
		return header, claims, "", nil, ErrInvalidToken
	}

	if err := json.Unmarshal(claimsBytes, &claims); err != nil {
		return header, claims, "", nil, ErrInvalidToken
	}

	return header, claims, segments[0] + "." + segments[1], signature, nil
}

func decodeJWTPart(part string) ([]byte, error) {
	return base64.RawURLEncoding.DecodeString(part)
}

func verifyRS256Signature(key *rsa.PublicKey, signingInput string, signature []byte) error {
	sum := sha256.Sum256([]byte(signingInput))
	return rsa.VerifyPKCS1v15(key, crypto.SHA256, sum[:], signature)
}

func parseRSAPublicKey(modulusValue, exponentValue string) (*rsa.PublicKey, error) {
	modulusBytes, err := base64.RawURLEncoding.DecodeString(modulusValue)
	if err != nil {
		return nil, err
	}

	exponentBytes, err := base64.RawURLEncoding.DecodeString(exponentValue)
	if err != nil {
		return nil, err
	}

	exponent := 0
	for _, currentByte := range exponentBytes {
		exponent = exponent<<8 + int(currentByte)
	}

	if exponent == 0 {
		return nil, ErrInvalidToken
	}

	return &rsa.PublicKey{
		N: new(big.Int).SetBytes(modulusBytes),
		E: exponent,
	}, nil
}
